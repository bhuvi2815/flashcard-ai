# ===== MongoDB Atlas connection string =====
# Get this from MongoDB Atlas dashboard -> Connect -> Drivers
# Looks like: mongodb+srv://username:password@cluster.mongodb.net/
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/

# Name of the database to use inside that cluster
DB_NAME=flashcard_ai_db

# ===== JWT settings (used to sign login tokens) =====
# This can be ANY long random string. Generate one using:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_long_random_secret_string

JWT_ALGORITHM=HS256

# How long a login session stays valid (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS: which frontend URL is allowed to call this backend =====
# During local dev this is your Next.js dev server
# After deployment, change this to your Vercel URL
FRONTEND_ORIGIN=http://localhost:3000
